# Application
APP_NAME=GitFolio
APP_ENV=development
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/gitfolio
SYNC_DATABASE_URL=postgresql://postgres:password@localhost:5432/gitfolio

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret
GITHUB_REDIRECT_URI=http://localhost:3000/api/auth/callback/github

# Anthropic (Claude AI)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_ONE_TIME_PRICE_ID=price_your_one_time_price_id
STRIPE_SUBSCRIPTION_PRICE_ID=price_your_subscription_price_id

# Redis
REDIS_URL=redis://localhost:6379

# Frontend URL
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
